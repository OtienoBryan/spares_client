/* Definition of the design system. All colors, gradients, fonts, etc should be defined here. 
All colors MUST be HSL.
*/

@layer base {
  :root {
    --background: 0 0% 100%;
    --foreground: 222.2 84% 4.9%;

    --card: 0 0% 100%;
    --card-foreground: 222.2 84% 4.9%;

    --popover: 0 0% 100%;
    --popover-foreground: 222.2 84% 4.9%;

    /* #5C4033 -> hsl(19 28% 28%) */
    --primary: 19 28% 28%;
    --primary-foreground: 0 0% 98%;

    --secondary: 19 20% 90%;
    --secondary-foreground: 19 28% 28%;

    --muted: 19 15% 95%;
    --muted-foreground: 215.4 16.3% 46.9%;

    --accent: 19 40% 75%;
    --accent-foreground: 19 28% 28%;

    /* Match wine tones to primary brand color */
    --wine: 19 28% 28%;
    --wine-light: 19 28% 38%;
    --gold: 35 75% 55%;
    --gold-light: 35 65% 70%;
    
    --gradient-wine: linear-gradient(135deg, hsl(var(--wine)), hsl(var(--wine-light)));
    --gradient-gold: linear-gradient(135deg, hsl(var(--gold)), hsl(var(--gold-light)));
    --gradient-hero: linear-gradient(135deg, hsl(var(--wine)), hsl(19 28% 35%), hsl(35 45% 45%));
    /* Shining primary gradient */
    --gradient-primary: linear-gradient(
      135deg,
      hsl(19 28% 23%),
      hsl(19 28% 28%),
      hsl(19 28% 33%)
    );

    --destructive: 0 84.2% 60.2%;
    --destructive-foreground: 210 40% 98%;

    --border: 214.3 31.8% 91.4%;
    --input: 214.3 31.8% 91.4%;
    --ring: 222.2 84% 4.9%;

    --radius: 0.5rem;

    --sidebar-background: 0 0% 98%;

