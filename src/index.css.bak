  /* Add left margin for sidebar on desktop */
  @media (min-width: 1024px) {
    /* Add margin to page content that comes after navigation */
    body > #root > div > div:has(> section):not(:has(nav)):not(:has(footer)) {
      margin-left: 16rem; /* 256px for w-64 sidebar */
    }
    
    /* But keep navigation and footer full width */
    nav,
    footer {
      margin-left: 0 !important;
    }
    
    /* Align hero/slider start after the permanent sidebar */
    section.hero-section,
    section[class*="hero"] {
      margin-left: 16rem !important;
      width: auto !important;
      position: relative;
      left: 0;
    }
    
    /* Content containers should have margin */
    .container,
    main:not(:has(nav)) {
      margin-left: 16rem;
    }
  }
